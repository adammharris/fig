name = Release (crate)

# Publish the crates.io crate (fig + fig-macros, from bindings/rust). There is
# no Zig package step: Zig has no central registry — consumers `zig fetch`
# this repo at a git tag, so pushing the tag *is* the Zig release. The macOS
# CLI binary + Homebrew tap bump is a separate workflow (homebrew.yml);
# Linux/Windows/WASI CLI binaries are release-binaries.yml.
#
# The two npm packages (bindings/typescript's @diaryx/fig and
# bindings/wasi's @diaryx/fig-wasi) live in their own files —
# release-npm.figl and release-npm-wasi.figl — split out from this one so
# each publish, on its own tag line and with its own required secret, can run
# (and be re-triggered) independently of the others.
#
# This job LIVEs on its own tag line (also runnable by hand via
# `workflow_dispatch`, which runs it unconditionally): `rust/v*.*.*`. See
# "Release tagging" in docs/VERSIONING.md for the full per-artifact tag
# scheme (there's also a `core/v*.*.*` line that nothing here listens for —
# it exists for `zig fetch` + the ABI semver baseline, not npm/crates.io).
# The crate carries the `license`, `description`, and `readme` crates.io
# needs (the README and license text are vendored in from the repo root by
# the `vendor-rust` step that runs before `cargo publish`).
#
# `rust/*` is an independent track with no required relation to its tag's
# version beyond the cross-artifact floor (`zig build version-floor`, checked
# below): it publishes whatever Cargo.toml says and no-ops if that exact
# version is already out.
#
# Required repository secret:
# CARGO_REGISTRY_TOKEN  — crates.io API token with publish rights (already set)
on
> workflow_dispatch = {}
> push.tags = [rust/v*.*.*]

permissions.id-token = write
permissions.contents = read

jobs.crate
> name = Publish crate (crates.io)
> runs-on = ubuntu-latest

jobs.crate.steps[]
> uses = actions/checkout@v7
> # cargo-semver-checks (below) needs full history + tags: its baseline is the
> # most recent `rust/v*` tag, discovered the same way ci.figl's
> # `rust-semver` job discovers its own baseline.
> with.fetch-depth = 0
+
> # build.rs compiles the core, and `vendor-rust` bundles the Zig source into
> # the published crate.
> uses = mlugg/setup-zig@v2
> with.version = 0.16.0
+
> # cargo-semver-checks reads rustdoc JSON, which only nightly rustdoc emits —
> # see ci.figl's `rust-semver` job for why this is a dated pin rather
> # than `@nightly`. Keep this pin in sync with that job's.
> uses = dtolnay/rust-toolchain@master
> with.toolchain = nightly-2026-06-15
+
> uses = taiki-e/install-action@v2
> with.tool = cargo-semver-checks
+
> # Same gate ci.figl's `rust-semver` job runs on every push/PR — re-run
> # it here so a release can never ship a native Rust API break that exceeds
> # what the crate's version bump allows, even if that CI job was skipped,
> # disabled, or its result went unnoticed. Baseline discovery excludes the
> # tag that triggered this run: HEAD *is* that tag's commit, so without
> # `--exclude`, `git describe` would resolve to the tag itself and the check
> # would always compare the crate against itself (i.e. never fail).
> name = Check the fig crate's Rust API against the last release tag
> working-directory = bindings/rust
> run = '''
set -euo pipefail
tag="$(git describe --tags --abbrev=0 --match 'rust/v*' --exclude "$GITHUB_REF_NAME" 2>/dev/null || true)"
if [ -z "$tag" ]; then
  echo "cargo-semver-checks: no prior rust/v* tag found — skipping (nothing to diff against)."
  exit 0
fi
echo "cargo-semver-checks: baseline $tag"
cargo semver-checks --package fig --baseline-rev "$tag"

'''
+
> # Switch back to stable for the rest of the job (test/vendor/publish) — the
> # nightly toolchain above was only needed for cargo-semver-checks' rustdoc
> # JSON.
> uses = dtolnay/rust-toolchain@stable
+
> # The crate is an independent track (see the header comment above) — this
> # only checks it (and everything else) stays >= the core it embeds, not
> # that it equals the tag.
> name = Verify the cross-artifact version floor
> run = zig build version-floor
+
> # --all-features so the serde- and derive-gated integration tests also run
> # (they are not in the default feature set).
> run = cargo test --workspace --all-features --locked
> working-directory = bindings/rust
+
> # Cross-compile each tier-1 target's libfig.a (default language set) into its
> # fig-sys-<target> payload crate's git-ignored lib/. Zig cross-compiles every
> # target from this one runner. Must precede packaging: the payload crates ship
> # lib/<archive> via their `include` list.
> name = Build prebuilt payload libraries
> working-directory = bindings/rust
> run = bash scripts/build-payload-lib.sh all
+
> # Vendors the Zig source into fig-sys AND fans the root LICENSE files out into
> # each crate dir — must run before publishing so the license text (and the
> # source-build fallback tree) are present in every packaged tarball.
> name = Vendor the Zig source and licenses into the crates
> run = zig build vendor-rust
+
> # Publish the whole graph bottom-up — crates.io rejects an upload whose
> # dependencies aren't already indexed, so the order is:
> #   payload crates -> fig-sys -> fig-macros -> fig
> # Two hazards this loop survives, both worst on the FIRST release (all crates
> # brand new):
> #   * crates.io throttles *new-crate* creation to a small burst (~5) then a slow
> #     refill; publishing >5 first-time crates (6 new here: fig-sys + 5 payloads)
> #     trips a 429, so we wait out one refill window (~11 min) and retry. Later
> #     releases publish new *versions* (far higher limit), so this matters once.
> #   * idempotent: an "already uploaded/exists" response counts as success, so a
> #     re-run after a partial publish skips the crates that already landed.
> name = Publish to crates.io (bottom-up)
> working-directory = bindings/rust
> env.CARGO_REGISTRY_TOKEN = ${{ secrets.CARGO_REGISTRY_TOKEN }}
> run = '''
set -uo pipefail
publish() {
  local crate="$1" attempt out
  for attempt in $(seq 1 8); do
    if out=$(cargo publish -p "$crate" --allow-dirty 2>&1); then
      echo "$out"; return 0
    fi
    echo "$out"
    if echo "$out" | grep -qiE 'already (uploaded|exists)'; then
      echo "::notice::$crate already on crates.io — skipping"; return 0
    fi
    if echo "$out" | grep -qiE 'rate limit|too many|429|try again'; then
      echo "::warning::$crate rate-limited by crates.io (new-crate burst); waiting 11m for refill"
      sleep 660; continue
    fi
    echo "publish $crate failed (attempt $attempt); retrying in 30s (index propagation?)"
    sleep 30
  done
  echo "::error::failed to publish $crate after retries"; return 1
}
for crate in \
  fig-sys-macos-arm64 fig-sys-linux-x64-gnu fig-sys-linux-arm64-gnu \
  fig-sys-windows-x64-msvc fig-sys-wasm32; do
  publish "$crate"
done
publish fig-sys
publish fig-macros
publish fig

'''
