{
  "name": "@adammharris/fig",
  "version": "2.4.0",
  "description": "JSON/JSONC/JSON5/YAML/TOML parsing (plus optional ZON), comment-preserving editing, and cross-format serialization, backed by a Zig core compiled to WebAssembly.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE-MIT", "LICENSE-APACHE"],
  "keywords": [
    "json",
    "jsonc",
    "json5",
    "yaml",
    "toml",
    "zon",
    "config",
    "parser",
    "frontmatter",
    "comment-preserving",
    "cross-format",
    "webassembly",
    "wasm"
  ],
  "author": "Adam Harris <amh421@icloud.com>",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/adammharris/fig/blob/main/docs/typescript.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adammharris/fig.git",
    "directory": "bindings/typescript"
  },
  "bugs": {
    "url": "https://github.com/adammharris/fig/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:wasm": "node scripts/build-wasm.mjs",
    "build": "npm run build:wasm && tsc -p tsconfig.json",
    "prepack": "node scripts/vendor-publish-files.mjs",
    "prepublishOnly": "npm run build && npm test",
    "test": "node --experimental-transform-types --test 'test/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "sideEffects": false
}
